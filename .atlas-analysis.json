  "keyFeatures": [
    "Horizontally scalable pub-sub messaging",
    "Multi-tenancy with authentication and authorization",
    "Geo-replication across clusters",
    "Pulsar Functions for serverless stream processing",
    "Pulsar IO connectors for external integrations",
    "Tiered storage for cost-effective data retention",
    "Strong ordering and consistency guarantees",
    "Schema registry and evolution",
    "REST Admin API for cluster management"
  ],
  "publicApiSurface": [
    "PulsarClient - Main client interface",
    "Producer - Publish messages to topics",
    "Consumer - Subscribe and consume messages",
    "Reader - Read messages from specific positions",
    "Message - Message data structure",
    "Schema - Schema definitions and serialization",
    "pulsar-admin - Administrative CLI tool",
    "pulsar-client - Client CLI tool",
    "REST Admin API - HTTP API for cluster management",
    "/admin/v2/tenants - Tenant management endpoint",
    "/admin/v2/namespaces - Namespace management endpoint",
    "/admin/v2/persistent - Topic management endpoint",
    "/admin/v2/schemas - Schema management endpoint",
    "/admin/v2/clusters - Cluster management endpoint",
